{
  "name": "novapay",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "dev:api": "pnpm --filter @novapay/api dev",
    "dev:web": "pnpm --filter @novapay/web dev",
    "build:api": "pnpm --filter @novapay/api build",
    "build:web": "pnpm --filter @novapay/web build",
    "lint:api": "pnpm --filter @novapay/api lint",
    "lint:web": "pnpm --filter @novapay/web lint"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.0.0"
}
