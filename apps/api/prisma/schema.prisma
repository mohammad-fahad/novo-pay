// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}



model Account {
  id            String        @id @default(uuid())
  userId        String
  currency      String        @default("USD")
  balance       Decimal       @default(0) @db.Decimal(20, 8)
  createdAt     DateTime      @default(now())
  ledgerEntries LedgerEntry[]
}

model Transaction {
  id             String         @id @default(uuid())
  amount         Decimal        @db.Decimal(20, 8)
  currency       String
  type           TransactionType
  status        String        // "PENDING", "COMPLETED", "FAILED"
  idempotencyKey String         @unique
  createdAt      DateTime       @default(now())
  ledgerEntries  LedgerEntry[]
}

model LedgerEntry {
  id            String      @id @default(uuid())
  accountId     String
  transactionId String
  type          EntryType
  amount        Decimal     @db.Decimal(20, 8)
  account       Account     @relation(fields: [accountId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([accountId])
  @@index([transactionId])
}


model IdempotencyRecord {
  id             String   @id @default(uuid())
  key            String   @unique
  requestPayload Json     // To detect Scenario E (Payload mismatch)
  responseBody   Json?    // Cached response
  status         String   // "PROCESSING" or "COMPLETED"
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
}

model FxQuote {
  id            String    @id @default(uuid())
  fromCurrency  String
  toCurrency    String
  rate          Decimal   @db.Decimal(20, 6) // Rates require high precision
  expiresAt     DateTime
  usedAt        DateTime? // To ensure a quote is only used once
  createdAt     DateTime  @default(now())
}


enum EntryType {
  DEBIT
  CREDIT
}

enum TransactionType {
  TRANSFER
  PAYROLL
}
